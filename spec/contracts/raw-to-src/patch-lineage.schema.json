{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw To SRC Patch Lineage",
  "type": "object",
  "required": [
    "run_id",
    "workflow_key",
    "events"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "workflow_key": {
      "type": "string",
      "const": "product.raw-to-src"
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "patch_id",
          "stage_id",
          "actor_role",
          "patch_scope",
          "patch_mode",
          "issue_code",
          "target_fields",
          "action",
          "outcome"
        ],
        "properties": {
          "patch_id": {
            "type": "string"
          },
          "stage_id": {
            "type": "string"
          },
          "actor_role": {
            "type": "string"
          },
          "patch_scope": {
            "type": "string",
            "enum": [
              "structural",
              "semantic"
            ]
          },
          "patch_mode": {
            "type": "string",
            "enum": [
              "minimal_patch",
              "no_patch"
            ]
          },
          "issue_code": {
            "type": "string"
          },
          "target_fields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "action": {
            "type": "string"
          },
          "outcome": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
