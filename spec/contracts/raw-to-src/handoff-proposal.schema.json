{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw-to-SRC Handoff Proposal",
  "type": "object",
  "required": [
    "handoff_id",
    "from_skill",
    "to_skill",
    "source_run_id",
    "primary_artifact_ref",
    "supporting_artifact_refs",
    "gate_result_ref",
    "evidence_bundle_refs",
    "required_context",
    "expected_output_type",
    "created_at"
  ],
  "properties": {
    "handoff_id": {
      "type": "string"
    },
    "from_skill": {
      "type": "string",
      "const": "ll-product-raw-to-src"
    },
    "to_skill": {
      "type": "string"
    },
    "source_run_id": {
      "type": "string"
    },
    "primary_artifact_ref": {
      "type": "string"
    },
    "supporting_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gate_result_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_bundle_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_output_type": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
