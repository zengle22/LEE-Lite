# Runtime state stays outside the project tree.
tmp/
temp/
scratch/
runtime/
sessions/
cache/
logs/
debug/
drafts/
misc/
stuff/
backup/
old/
final2/
test2/
new/

# Python runtime residue.
__pycache__/
*.py[cod]

# Local environment and machine files.
.env
.env.local
.DS_Store
Thumbs.db
*.log
*.pid
*.lock

# Keep the local workspace shell
# Track specific files, ignore everything else
!.local/README.md
!.local/.gitignore
!.local/agent.md
.local/*

# Claude Code knowledge maps (auto-generated)
# Ignore agent.md in all subdirectories
.claude/agent.md
.claude/*/agent.md
.claude/*/*/agent.md
cli/agent.md
cli/*/agent.md
cli/*/*/agent.md
cli/*/*/*/agent.md
docs/agent.md
docs/*/agent.md
docs/*/*/agent.md
examples/agent.md
examples/*/agent.md
examples/*/*/agent.md
examples/*/*/*/agent.md
examples/*/*/*/*/agent.md
skills/agent.md
skills/*/agent.md
skills/*/*/agent.md
skills/*/*/*/agent.md
spec/agent.md
spec/*/agent.md
spec/*/*/agent.md
tests/agent.md
tests/*/agent.md
tests/*/*/agent.md

# Keep root agent.md (tracked)
!/agent.md

# Workflow runtime output
.workflow/
.workflow/*

# Artifact outputs (typically generated)
artifacts/
artifacts/*/

# LEE runtime directories
.lee/
.lee/*
.artifacts/
.artifacts/*
.project/
.project/*

# Evidence outputs (runtime)
evidence/
evidence/*/

# Node.js dependencies
node_modules/
package-lock.json
package.json
