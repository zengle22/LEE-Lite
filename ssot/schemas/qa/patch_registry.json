{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Patch Registry",
  "description": "ADR-049: Index file for experience patches within a single FEAT subdirectory",
  "type": "object",
  "required": ["patch_registry_version", "feat_id", "patches"],
  "properties": {
    "patch_registry_version": {
      "type": "string",
      "description": "Schema version for the registry format",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "feat_id": {
      "type": "string",
      "description": "The FEAT-ID this registry belongs to (e.g., feat.training-plan)"
    },
    "patches": {
      "type": "array",
      "description": "List of all experience patches in this FEAT",
      "items": {
        "type": "object",
        "required": ["id", "status", "change_class", "created_at", "title"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^UXPATCH-\\d{4}$",
            "description": "Patch ID, e.g., UXPATCH-0001"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "active", "validated", "pending_backwrite", "backwritten", "retain_in_code", "upgraded_to_src", "superseded", "discarded", "archived"]
          },
          "change_class": {
            "type": "string",
            "enum": ["visual", "interaction", "semantic"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp"
          },
          "title": {
            "type": "string",
            "description": "Short title of the patch"
          },
          "patch_file": {
            "type": "string",
            "description": "Relative filename of the patch YAML, e.g., UXPATCH-0001__button-fix.yaml"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "When this registry was last modified"
    }
  }
}
