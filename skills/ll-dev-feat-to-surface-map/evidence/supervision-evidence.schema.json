  "properties": {
    "workflow_key": { "type": "string" },
    "run_id": { "type": "string" },
    "reviewed_at": { "type": "string" },
    "reviewer": { "type": "string" },
    "decision": { "type": "string" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
