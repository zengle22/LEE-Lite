{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-dev-feat-to-surface-map input",
  "type": "object",
  "required": ["artifact_type", "status", "schema_version", "feat_refs", "features", "source_refs"],
  "properties": {
    "artifact_type": { "type": "string", "const": "feat_freeze_package" },
    "status": { "type": "string" },
    "schema_version": { "type": "string" },
    "feat_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["feat_ref", "title", "goal", "scope", "constraints", "acceptance_checks", "source_refs"],
        "properties": {
          "feat_ref": { "type": "string" },
          "title": { "type": "string" },
          "goal": { "type": "string" },
          "scope": { "type": "array", "items": { "type": "string" } },
          "constraints": { "type": "array", "items": { "type": "string" } },
          "acceptance_checks": { "type": "array", "items": { "type": "object" } },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "design_impact_required": { "type": "boolean" },
          "ui_required": { "type": "boolean" },
          "design_surfaces": { "type": "object" },
          "arch_ref": { "type": "string" },
          "api_ref": { "type": "string" },
          "ui_ref": { "type": "string" },
          "prototype_ref": { "type": "string" },
          "tech_ref": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
