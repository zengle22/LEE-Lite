{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["response_ref", "trace", "execution_status", "output_artifacts"],
  "properties": {
    "response_ref": {
      "type": "string",
      "description": "Reference to the orchestrator response"
    },
    "trace": {
      "type": "object",
      "description": "Execution trace with state machine transitions",
      "properties": {
        "states": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "enum": ["START", "APIPLAN_RUNNING", "TRACEABILITY_VALIDATING", "MANIFEST_RUNNING", "SPEC_RUNNING", "COMPLETE", "FAILED"]
              },
              "timestamp": {"type": "string"},
              "skill_calls": {
                "type": "array",
                "items": {"type": "string"}
              },
              "error": {"type": "string"}
            }
          }
        }
      }
    },
    "execution_status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    },
    "output_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Path to generated artifact"
      }
    }
  }
}
