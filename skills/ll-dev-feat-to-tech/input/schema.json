{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-dev-feat-to-tech input",
  "type": "object",
  "required": ["artifact_type", "status", "schema_version", "feat_refs", "features", "source_refs"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "feat_freeze_package"
    },
    "status": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "feat_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["feat_ref", "title", "scope", "constraints", "acceptance_checks"],
        "properties": {
          "feat_ref": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "scope": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "acceptance_checks": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "design_impact_required": {
            "type": "boolean"
          },
          "candidate_design_surfaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "surface_map_required_reason": {
            "type": "string"
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "integration_context": {
      "type": "object",
      "required": [
        "workflow_inventory",
        "module_boundaries",
        "legacy_fields_states_interfaces",
        "canonical_ownership",
        "compatibility_constraints",
        "migration_modes",
        "legacy_invariants",
        "gate_audit_evidence",
        "source_refs"
      ],
      "properties": {
        "workflow_inventory": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "module_boundaries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "legacy_fields_states_interfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "canonical_ownership": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "compatibility_constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "migration_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "legacy_invariants": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "gate_audit_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
