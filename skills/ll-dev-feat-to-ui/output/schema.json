{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-dev-feat-to-ui output",
  "type": "object",
  "required": [
    "artifact_type",
    "workflow_key",
    "status",
    "schema_version",
    "feat_ref",
    "ui_spec_count",
    "ui_spec_refs",
    "ui_specs",
    "completeness_result",
    "source_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "ui_spec_package"
    },
    "workflow_key": {
      "type": "string",
      "const": "dev.feat-to-ui"
    },
    "status": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "feat_ref": {
      "type": "string"
    },
    "package_entry_spec_id": {
      "type": "string"
    },
    "package_exit_spec_id": {
      "type": "string"
    },
    "ui_spec_count": {
      "type": "integer",
      "minimum": 1
    },
    "ui_spec_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "ui_specs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ui_spec_id",
          "page_name",
          "page_type",
          "output_ref",
          "completeness_result"
        ],
        "additionalProperties": true
      }
    },
    "flow_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "relation"
        ],
        "additionalProperties": true
      }
    },
    "completeness_result": {
      "type": "string",
      "enum": [
        "pass",
        "conditional_pass",
        "fail"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
