{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-dev-feat-to-proto input",
  "type": "object",
  "required": ["artifact_type", "workflow_key", "status", "feat_refs", "features", "source_refs"],
  "properties": {
    "artifact_type": { "type": "string", "const": "feat_freeze_package" },
    "workflow_key": { "type": "string", "const": "product.epic-to-feat" },
    "status": { "type": "string" },
    "feat_refs": { "type": "array", "items": { "type": "string" } },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feat_ref", "title", "goal", "scope", "constraints", "acceptance_checks", "source_refs"],
        "properties": {
          "feat_ref": { "type": "string" },
          "title": { "type": "string" },
          "goal": { "type": "string" },
          "scope": { "type": "array", "items": { "type": "string" } },
          "constraints": { "type": "array", "items": { "type": "string" } },
          "acceptance_checks": { "type": "array", "items": {} },
          "source_refs": { "type": "array", "items": { "type": "string" } },
          "design_impact_required": { "type": "boolean" },
          "candidate_design_surfaces": { "type": "array", "items": { "type": "string" } },
          "surface_map_required_reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "source_refs": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
