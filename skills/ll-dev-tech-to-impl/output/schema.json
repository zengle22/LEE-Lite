{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-dev-tech-to-impl output",
  "type": "object",
  "required": [
    "artifact_type",
    "workflow_key",
    "workflow_run_id",
    "status",
    "schema_version",
    "package_role",
    "feat_ref",
    "impl_ref",
    "tech_ref",
    "source_refs",
    "package_semantics",
    "authority_scope",
    "selected_upstream_refs",
    "provisional_refs",
    "scope_boundary",
    "upstream_impacts",
    "normative_items",
    "informative_items",
    "repo_touch_points",
    "embedded_execution_contract",
    "change_controls",
    "required_steps",
    "suggested_steps",
    "implementation_task_breakdown",
    "acceptance_trace",
    "acceptance_to_task_mapping",
    "testset_mapping",
    "handoff_artifacts",
    "conflict_policy",
    "freshness_status",
    "rederive_triggers",
    "self_contained_policy",
    "repo_discrepancy_status",
    "workstream_assessment",
    "artifact_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "feature_impl_candidate_package"
    },
    "workflow_key": {
      "type": "string",
      "const": "dev.tech-to-impl"
    },
    "workflow_run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["in_progress", "execution_ready", "blocked"]
    },
    "schema_version": {
      "type": "string"
    },
    "package_role": {
      "type": "string",
      "const": "candidate"
    },
    "feat_ref": {
      "type": "string"
    },
    "impl_ref": {
      "type": "string"
    },
    "tech_ref": {
      "type": "string"
    },
    "arch_ref": {
      "type": ["string", "null"]
    },
    "api_ref": {
      "type": ["string", "null"]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "package_semantics": {
      "type": "object",
      "required": ["canonical_package", "execution_time_single_entrypoint", "domain_truth_source", "design_truth_source", "test_truth_source"],
      "properties": {
        "canonical_package": { "type": "boolean", "const": true },
        "execution_time_single_entrypoint": { "type": "boolean", "const": true },
        "domain_truth_source": { "type": "boolean", "const": false },
        "design_truth_source": { "type": "boolean", "const": false },
        "test_truth_source": { "type": "boolean", "const": false }
      },
      "additionalProperties": true
    },
    "authority_scope": {
      "type": "object",
      "required": ["upstream_truth_sources", "local_authority", "forbidden_authority"],
      "properties": {
        "upstream_truth_sources": { "type": "array", "items": { "type": "string" } },
        "local_authority": { "type": "array", "items": { "type": "string" } },
        "forbidden_authority": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "selected_upstream_refs": {
      "type": "object",
      "required": ["adr_refs", "src_ref", "epic_ref", "feat_ref", "tech_ref"],
      "properties": {
        "adr_refs": { "type": "array", "items": { "type": "string" } },
        "src_ref": { "type": "string" },
        "epic_ref": { "type": "string" },
        "feat_ref": { "type": "string" },
        "tech_ref": { "type": "string" },
        "arch_ref": { "type": ["string", "null"] },
        "api_ref": { "type": ["string", "null"] },
        "ui_ref": { "type": ["string", "null"] },
        "testset_ref": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "provisional_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "status", "impact_scope", "follow_up_action"],
        "properties": {
          "ref": { "type": "string" },
          "status": { "type": "string", "enum": ["provisional"] },
          "impact_scope": { "type": "string" },
          "follow_up_action": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "scope_boundary": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "upstream_impacts": {
      "type": "object",
      "required": ["adr", "src_epic_feat", "tech", "arch", "api", "ui", "testset"],
      "additionalProperties": true
    },
    "normative_items": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "informative_items": { "type": "array", "items": { "type": "string" } },
    "repo_touch_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["touch_ref", "unit_path", "surface", "mode", "detail", "repo_paths", "primary_repo_path", "placement_status"],
        "properties": {
          "touch_ref": { "type": "string" },
          "unit_path": { "type": "string" },
          "surface": { "type": "string", "enum": ["frontend", "backend", "shared"] },
          "mode": { "type": "string" },
          "detail": { "type": "string" },
          "repo_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "primary_repo_path": { "type": "string" },
          "placement_status": { "type": "string", "enum": ["existing_match", "proposed_new_module"] }
        },
        "additionalProperties": true
      }
    },
    "embedded_execution_contract": {
      "type": "object",
      "required": ["state_machine", "api_contracts", "ui_entry_exit", "invariants", "boundaries", "acceptance_checks"],
      "properties": {
        "state_machine": { "type": "array", "items": { "type": "string" } },
        "api_contracts": { "type": "array", "items": { "type": "string" } },
        "ui_entry_exit": {
          "type": "object",
          "required": ["entry", "success_exit", "failure_exit"],
          "properties": {
            "entry": { "type": "array", "items": { "type": "string" } },
            "success_exit": { "type": "array", "items": { "type": "string" } },
            "failure_exit": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "invariants": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "boundaries": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "acceptance_checks": { "type": "array", "minItems": 1, "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "change_controls": {
      "type": "object",
      "required": ["touch_set", "allowed_changes", "forbidden_changes"],
      "properties": {
        "touch_set": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "allowed_changes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "forbidden_changes": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "required_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "work", "done_when"],
        "properties": {
          "title": { "type": "string" },
          "work": { "type": "string" },
          "done_when": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "suggested_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "reason"],
        "properties": {
          "title": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "implementation_task_breakdown": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "title", "objective", "inputs", "touch_points", "outputs", "depends_on", "parallelizable_with", "acceptance_refs", "done_when"],
        "properties": {
          "step_id": { "type": "string" },
          "title": { "type": "string" },
          "objective": { "type": "string" },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "touch_points": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "parallelizable_with": { "type": "array", "items": { "type": "string" } },
          "acceptance_refs": { "type": "array", "items": { "type": "string" } },
          "done_when": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "acceptance_trace": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "acceptance_to_task_mapping": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["acceptance_ref", "scenario", "implemented_by", "evidence_expectation"],
        "properties": {
          "acceptance_ref": { "type": "string" },
          "scenario": { "type": "string" },
          "implemented_by": { "type": "array", "items": { "type": "string" } },
          "evidence_expectation": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "testset_mapping": {
      "type": "object",
      "required": ["testset_ref", "mapping_policy", "mappings"],
      "properties": {
        "testset_ref": { "type": ["string", "null"] },
        "mapping_policy": { "type": "string", "const": "TESTSET_over_IMPL_when_present" },
        "mappings": { "type": "array", "minItems": 1, "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "handoff_artifacts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "conflict_policy": {
      "type": "object",
      "required": ["upstream_precedence", "testset_precedence", "repo_discrepancy_policy"],
      "properties": {
        "upstream_precedence": { "type": "array", "items": { "type": "string" } },
        "testset_precedence": { "type": "string" },
        "repo_discrepancy_policy": { "type": "string", "enum": ["explicit_discrepancy_handling_required"] }
      },
      "additionalProperties": true
    },
    "freshness_status": {
      "type": "string",
      "enum": ["fresh_on_generation", "needs_review", "stale"]
    },
    "rederive_triggers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "self_contained_policy": {
      "type": "object",
      "required": ["principle", "expand", "summary_only", "forbidden"],
      "properties": {
        "principle": { "type": "string" },
        "expand": { "type": "array", "items": { "type": "string" } },
        "summary_only": { "type": "array", "items": { "type": "string" } },
        "forbidden": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "repo_discrepancy_status": {
      "type": "object",
      "required": ["status", "policy"],
      "properties": {
        "status": { "type": "string" },
        "policy": { "type": "string" }
      },
      "additionalProperties": true
    },
    "workstream_assessment": {
      "type": "object",
      "required": ["frontend_required", "backend_required", "migration_required", "rationale"],
      "properties": {
        "frontend_required": { "type": "boolean" },
        "backend_required": { "type": "boolean" },
        "migration_required": { "type": "boolean" },
        "execution_surface_count": { "type": "integer" },
        "rationale": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "artifact_refs": {
      "type": "object",
      "required": [
        "bundle_markdown",
        "bundle_json",
        "impl_task",
        "upstream_design_refs",
        "integration_plan",
        "dev_evidence_plan",
        "smoke_gate_subject",
        "review_report",
        "acceptance_report",
        "defect_list",
        "handoff"
      ],
      "properties": {
        "bundle_markdown": { "type": "string" },
        "bundle_json": { "type": "string" },
        "impl_task": { "type": "string" },
        "upstream_design_refs": { "type": "string" },
        "frontend_workstream": { "type": ["string", "null"] },
        "backend_workstream": { "type": ["string", "null"] },
        "migration_cutover_plan": { "type": ["string", "null"] },
        "integration_plan": { "type": "string" },
        "dev_evidence_plan": { "type": "string" },
        "smoke_gate_subject": { "type": "string" },
        "review_report": { "type": "string" },
        "acceptance_report": { "type": "string" },
        "defect_list": { "type": "string" },
        "handoff": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

