{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-dev-tech-to-impl input",
  "type": "object",
  "required": [
    "artifact_type",
    "workflow_key",
    "workflow_run_id",
    "status",
    "schema_version",
    "feat_ref",
    "tech_ref",
    "selected_feat",
    "source_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "tech_design_package"
    },
    "workflow_key": {
      "type": "string",
      "const": "dev.feat-to-tech"
    },
    "workflow_run_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "feat_ref": {
      "type": "string"
    },
    "tech_ref": {
      "type": "string"
    },
    "arch_ref": {
      "type": ["string", "null"]
    },
    "api_ref": {
      "type": ["string", "null"]
    },
    "selected_feat": {
      "type": "object",
      "required": ["feat_ref", "title", "goal", "scope", "constraints"],
      "properties": {
        "feat_ref": { "type": "string" },
        "title": { "type": "string" },
        "goal": { "type": "string" },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acceptance_checks": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": true
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}

