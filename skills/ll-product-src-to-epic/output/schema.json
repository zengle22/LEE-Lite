{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-product-src-to-epic output",
  "type": "object",
  "required": [
    "artifact_type",
    "status",
    "schema_version",
    "workflow_key",
    "workflow_run_id",
    "epic_freeze_ref",
    "src_root_id",
    "downstream_workflow",
    "source_refs",
    "business_value_problem",
    "product_positioning",
    "actors_and_roles",
    "upstream_and_downstream",
    "epic_success_criteria"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "epic_freeze_package"
    },
    "status": {
      "type": "string",
      "enum": [
        "revised",
        "accepted",
        "frozen"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "workflow_key": {
      "type": "string",
      "const": "product.src-to-epic"
    },
    "workflow_run_id": {
      "type": "string",
      "minLength": 1
    },
    "epic_freeze_ref": {
      "type": "string",
      "minLength": 1
    },
    "src_root_id": {
      "type": "string",
      "minLength": 1
    },
    "downstream_workflow": {
      "type": "string",
      "const": "product.epic-to-feat"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "business_value_problem": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "product_positioning": {
      "type": "string",
      "minLength": 1
    },
    "actors_and_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "upstream_and_downstream": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "epic_success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollout_requirement": {
      "type": "object"
    },
    "rollout_plan": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
