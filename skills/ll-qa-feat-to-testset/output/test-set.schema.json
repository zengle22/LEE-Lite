{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-qa-feat-to-testset test-set main object",
  "type": "object",
  "required": [
    "id",
    "ssot_type",
    "workflow_key",
    "template_id",
    "feat_ref",
    "epic_ref",
    "src_ref",
    "title",
    "coverage_scope",
    "risk_focus",
    "preconditions",
    "environment_assumptions",
    "test_layers",
    "test_units",
    "functional_areas",
    "logic_dimensions",
    "state_model",
    "coverage_matrix",
    "coverage_exclusions",
    "pass_criteria",
    "evidence_required",
    "acceptance_traceability",
    "source_refs",
    "governing_adrs",
    "status"
  ],
  "properties": {
    "id": {"type": "string"},
    "ssot_type": {"type": "string", "const": "TESTSET"},
    "workflow_key": {"type": "string"},
    "template_id": {"type": "string"},
    "feat_ref": {"type": "string"},
    "epic_ref": {"type": "string"},
    "src_ref": {"type": "string"},
    "title": {"type": "string"},
    "coverage_scope": {"type": "array", "items": {"type": "string"}},
    "risk_focus": {"type": "array", "items": {"type": "string"}},
    "preconditions": {"type": "array", "items": {"type": "string"}},
    "environment_assumptions": {"type": "array", "items": {"type": "string"}},
    "test_layers": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "functional_areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "kind", "description", "related_entities", "related_commands", "acceptance_refs", "case_families"],
        "properties": {
          "key": {"type": "string"},
          "kind": {"type": "string"},
          "description": {"type": "string"},
          "related_entities": {"type": "array", "items": {"type": "string"}},
          "related_commands": {"type": "array", "items": {"type": "string"}},
          "acceptance_refs": {"type": "array", "items": {"type": "string"}},
          "case_families": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "logic_dimensions": {
      "type": "object",
      "required": ["universal", "stateful", "control_surface"],
      "properties": {
        "universal": {"type": "array", "items": {"type": "string"}},
        "stateful": {"type": "array", "items": {"type": "string"}},
        "control_surface": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "state_model": {
      "type": "object",
      "required": ["entities"],
      "properties": {
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["entity", "functional_area_key", "states", "valid_transitions", "guarded_actions"],
            "properties": {
              "entity": {"type": "string"},
              "functional_area_key": {"type": "string"},
              "states": {"type": "array", "items": {"type": "string"}},
              "valid_transitions": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}},
              "guarded_actions": {"type": "array", "items": {"type": "object"}}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "coverage_matrix": {
      "type": "object",
      "required": ["acceptances", "functional_areas", "risks", "state_entities"],
      "properties": {
        "acceptances": {"type": "array", "items": {"type": "object"}},
        "functional_areas": {"type": "array", "items": {"type": "object"}},
        "risks": {"type": "array", "items": {"type": "object"}},
        "state_entities": {"type": "array", "items": {"type": "object"}}
      },
      "additionalProperties": true
    },
    "coverage_goal": {
      "type": "object",
      "properties": {
        "line_rate_percent": {"type": "number"},
        "branch_rate_percent": {"type": "number"}
      },
      "additionalProperties": true
    },
    "branch_families": {"type": "array", "items": {"type": "string"}},
    "expansion_hints": {"type": "array", "items": {"type": "string"}},
    "qualification_expectation": {"type": "string"},
    "qualification_budget": {"type": "integer"},
    "max_expansion_rounds": {"type": "integer"},
    "test_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "unit_ref",
          "title",
          "priority",
          "input_preconditions",
          "trigger_action",
          "observation_points",
          "pass_conditions",
          "fail_conditions",
          "required_evidence"
        ],
        "properties": {
          "unit_ref": {"type": "string"},
          "acceptance_ref": {"type": "string"},
          "derivation_basis": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "title": {"type": "string"},
          "priority": {"type": "string"},
          "input_preconditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "trigger_action": {"type": "string"},
          "observation_points": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "pass_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "fail_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "required_evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "functional_area_key": {"type": "string"},
          "functional_area_keys": {"type": "array", "items": {"type": "string"}},
          "case_family": {"type": "string"},
          "logic_dimensions": {
            "type": "object",
            "properties": {
              "universal": {"type": "array", "items": {"type": "string"}},
              "stateful": {"type": "array", "items": {"type": "string"}},
              "control_surface": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          },
          "acceptance_refs": {"type": "array", "items": {"type": "string"}},
          "risk_refs": {"type": "array", "items": {"type": "string"}},
          "boundary_checks": {"type": "array", "items": {"type": "string"}}
        },
        "anyOf": [
          {"required": ["acceptance_ref"]},
          {"required": ["derivation_basis"]}
        ],
        "additionalProperties": true
      }
    },
    "coverage_exclusions": {"type": "array", "items": {"type": "string"}},
    "pass_criteria": {"type": "array", "items": {"type": "string"}},
    "evidence_required": {"type": "array", "items": {"type": "string"}},
    "acceptance_traceability": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "acceptance_ref",
          "acceptance_scenario",
          "given",
          "when",
          "then",
          "unit_refs",
          "coverage_status"
        ],
        "properties": {
          "acceptance_ref": {"type": "string"},
          "acceptance_scenario": {"type": "string"},
          "given": {"type": "string"},
          "when": {"type": "string"},
          "then": {"type": "string"},
          "unit_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "functional_area_keys": {"type": "array", "items": {"type": "string"}},
          "case_family": {"type": "string"},
          "risk_refs": {"type": "array", "items": {"type": "string"}},
          "coverage_status": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "governing_adrs": {"type": "array", "items": {"type": "string"}},
    "status": {
      "type": "string",
      "enum": ["draft", "review_ready", "approved", "frozen"]
    }
  },
  "additionalProperties": true
}
