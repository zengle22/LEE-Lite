{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-qa-feat-to-testset output",
  "type": "object",
  "required": [
    "artifact_type",
    "workflow_key",
    "workflow_run_id",
    "status",
    "schema_version",
    "package_role",
    "feat_ref",
    "test_set_ref",
    "derived_slug",
    "source_refs",
    "artifact_refs",
    "gate_subject_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "test_set_candidate_package"
    },
    "workflow_key": {
      "type": "string",
      "const": "qa.feat-to-testset"
    },
    "workflow_run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["in_progress", "review_pending", "approval_pending", "rejected"]
    },
    "schema_version": {
      "type": "string"
    },
    "package_role": {
      "type": "string",
      "const": "candidate"
    },
    "feat_ref": {
      "type": "string"
    },
    "test_set_ref": {
      "type": "string"
    },
    "derived_slug": {
      "type": "string"
    },
    "coverage_goal": {
      "type": "object",
      "properties": {
        "line_rate_percent": {"type": "number"},
        "branch_rate_percent": {"type": "number"}
      },
      "additionalProperties": true
    },
    "branch_families": {"type": "array", "items": {"type": "string"}},
    "expansion_hints": {"type": "array", "items": {"type": "string"}},
    "qualification_expectation": {"type": "string"},
    "qualification_budget": {"type": "integer"},
    "max_expansion_rounds": {"type": "integer"},
    "functional_areas": {
      "type": "array",
      "items": {"type": "object"}
    },
    "logic_dimensions": {
      "type": "object",
      "additionalProperties": true
    },
    "state_model": {
      "type": "object",
      "additionalProperties": true
    },
    "coverage_matrix": {
      "type": "object",
      "additionalProperties": true
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "artifact_refs": {
      "type": "object",
      "required": [
        "test_set",
        "analysis",
        "strategy",
        "review_report",
        "acceptance_report",
        "freeze_gate",
        "handoff"
      ],
      "properties": {
        "test_set": {"type": "string"},
        "analysis": {"type": "string"},
        "strategy": {"type": "string"},
        "review_report": {"type": "string"},
        "acceptance_report": {"type": "string"},
        "freeze_gate": {"type": "string"},
        "handoff": {"type": "string"}
      },
      "additionalProperties": true
    },
    "gate_subject_refs": {
      "type": "object",
      "required": [
        "analysis_review",
        "strategy_review",
        "test_set_approval"
      ],
      "properties": {
        "analysis_review": {"type": "string"},
        "strategy_review": {"type": "string"},
        "test_set_approval": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
