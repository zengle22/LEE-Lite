{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-qa-feat-to-testset gate subject",
  "type": "object",
  "required": [
    "subject_id",
    "gate_type",
    "subject_kind",
    "workflow_key",
    "workflow_run_id",
    "feat_ref",
    "candidate_package_ref",
    "artifact_ref"
  ],
  "properties": {
    "subject_id": {"type": "string"},
    "gate_type": {
      "type": "string",
      "enum": ["analysis_review", "strategy_review", "test_set_approval"]
    },
    "subject_kind": {"type": "string", "const": "gate_subject"},
    "workflow_key": {"type": "string", "const": "qa.feat-to-testset"},
    "workflow_run_id": {"type": "string"},
    "feat_ref": {"type": "string"},
    "candidate_package_ref": {"type": "string"},
    "artifact_ref": {"type": "string"},
    "related_refs": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
