{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LEE Product Raw To SRC Input",
  "type": "object",
  "required": [
    "artifact_type",
    "input_type",
    "title",
    "body",
    "source_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "raw-input"
    },
    "input_type": {
      "type": "string",
      "enum": [
        "adr",
        "raw_requirement",
        "business_opportunity",
        "business_opportunity_freeze"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "body": {
      "type": "string",
      "minLength": 10
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object"
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
