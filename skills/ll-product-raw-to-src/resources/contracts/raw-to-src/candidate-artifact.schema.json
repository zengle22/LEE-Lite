{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw-to-SRC Candidate Artifact",
  "type": "object",
  "required": [
    "artifact_type",
    "workflow_key",
    "workflow_run_id",
    "title",
    "status",
    "source_kind",
    "source_refs",
    "sections_present"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "src_candidate"
    },
    "workflow_key": {
      "type": "string",
      "const": "product.raw-to-src"
    },
    "workflow_run_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "freeze_ready",
        "needs_review",
        "blocked"
      ]
    },
    "source_kind": {
      "type": "string"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "sections_present": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source_kind": {
            "const": "governance_bridge_src"
          }
        }
      },
      "then": {
        "properties": {
          "sections_present": {
            "allOf": [
              {
                "contains": {
                  "const": "Bridge Context"
                }
              },
              {
                "contains": {
                  "const": "治理变更摘要"
                }
              }
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
