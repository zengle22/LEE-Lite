{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw To SRC Run State",
  "type": "object",
  "required": [
    "run_id",
    "workflow_key",
    "current_state",
    "recommended_action",
    "state_history"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "workflow_key": {
      "type": "string",
      "const": "product.raw-to-src"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "input_invalid",
        "input_fixing",
        "intake_failed",
        "intake_fixing",
        "structural_fixing",
        "structural_failed",
        "semantic_reviewing",
        "semantic_fixing",
        "semantic_failed",
        "retry_recommended",
        "freeze_ready",
        "handed_off",
        "blocked",
        "completed"
      ]
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "next_skill",
        "retry",
        "human_handoff",
        "blocked"
      ]
    },
    "state_history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "state",
          "stage_id",
          "role"
        ],
        "properties": {
          "state": {
            "type": "string"
          },
          "stage_id": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
