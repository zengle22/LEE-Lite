{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw-to-SRC Proposed Next Actions",
  "type": "object",
  "required": [
    "workflow_key",
    "run_id",
    "current_result_state",
    "recommended_action",
    "recommended_target_skill",
    "recommended_queue_path",
    "recommend_freeze"
  ],
  "properties": {
    "workflow_key": {
      "type": "string",
      "const": "product.raw-to-src"
    },
    "run_id": {
      "type": "string"
    },
    "current_result_state": {
      "type": "string"
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "next_skill",
        "retry",
        "human_handoff",
        "blocked"
      ]
    },
    "recommended_target_skill": {
      "type": "string"
    },
    "recommended_queue_path": {
      "type": "string"
    },
    "recommended_handoff_action": {
      "type": "string",
      "enum": [
        "materialize_handoff",
        "materialize_retry_handoff",
        "materialize_human_handoff",
        "no_handoff"
      ]
    },
    "recommend_freeze": {
      "type": "boolean"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
