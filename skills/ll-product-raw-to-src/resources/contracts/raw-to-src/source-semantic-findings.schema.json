{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Raw To SRC Source Semantic Findings",
  "type": "object",
  "required": [
    "run_id",
    "workflow_key",
    "stage_id",
    "reviewed_artifact_ref",
    "decision",
    "summary",
    "findings"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "workflow_key": {
      "type": "string",
      "const": "product.raw-to-src"
    },
    "stage_id": {
      "type": "string",
      "const": "source_semantic_review"
    },
    "reviewed_artifact_ref": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "pass",
        "revise"
      ]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "source_stage",
          "severity",
          "type",
          "description"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "source_stage": {
            "type": "string",
            "const": "source_semantic_review"
          },
          "severity": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
