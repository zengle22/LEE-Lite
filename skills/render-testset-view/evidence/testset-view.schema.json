{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TestsetView",
  "description": "Legacy testset-compatible view rendered from dual-chain artifacts",
  "type": "object",
  "required": ["assigned_id", "test_set_ref", "title", "functional_areas", "coverage_matrix"],
  "properties": {
    "assigned_id": {
      "type": "string",
      "description": "Unique identifier derived from feature_id",
      "pattern": "^TESTSET-[A-Z0-9-]+$"
    },
    "test_set_ref": {
      "type": "string",
      "description": "Reference matching assigned_id"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title",
      "minLength": 1
    },
    "functional_areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "coverage_count", "passed_count", "failed_count"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "coverage_count": {
            "type": "integer",
            "minimum": 0
          },
          "passed_count": {
            "type": "integer",
            "minimum": 0
          },
          "failed_count": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "coverage_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["coverage_id", "capability", "lifecycle_status", "passed", "failed"],
        "properties": {
          "coverage_id": {
            "type": "string",
            "minLength": 1
          },
          "capability": {
            "type": "string",
            "minLength": 1
          },
          "lifecycle_status": {
            "type": "string",
            "enum": ["designed", "passed", "failed", "blocked", "cut", "obsolete", "waived", "executed"]
          },
          "passed": {
            "type": "boolean"
          },
          "failed": {
            "type": "boolean"
          }
        }
      }
    },
    "logic_dimensions": {
      "type": "object",
      "properties": {
        "p0_count": {
          "type": "integer",
          "minimum": 0
        },
        "p1_count": {
          "type": "integer",
          "minimum": 0
        },
        "p2_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "generation_metadata": {
      "type": "object",
      "required": ["generated_at", "source_artifacts"],
      "properties": {
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
