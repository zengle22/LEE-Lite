{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-project-init supervision evidence",
  "type": "object",
  "required": [
    "skill_id",
    "run_id",
    "role",
    "reviewed_inputs",
    "reviewed_outputs",
    "reviewed_paths",
    "semantic_findings",
    "decision",
    "reason"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "const": "ll-project-init"
    },
    "run_id": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "const": "supervisor"
    },
    "reviewed_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewed_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "semantic_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "check",
          "status",
          "message"
        ],
        "properties": {
          "check": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "pass",
        "revise",
        "reject"
      ]
    },
    "reason": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
