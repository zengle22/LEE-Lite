{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-project-init execution evidence",
  "type": "object",
  "required": [
    "skill_id",
    "run_id",
    "role",
    "request_path",
    "repo_root",
    "inputs",
    "outputs",
    "commands_run",
    "structural_results",
    "key_decisions",
    "uncertainties",
    "created_paths",
    "updated_paths",
    "skipped_existing_paths"
  ],
  "properties": {
