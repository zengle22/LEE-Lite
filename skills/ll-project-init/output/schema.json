{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-project-init output",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "project_name",
    "project_slug",
    "repo_root",
    "template_profile",
    "status",
    "generated_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "project_init_package"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "project_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,63}$"
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "template_profile": {
      "type": "string",
      "const": "lee-skill-first"
    },
    "status": {
      "type": "string",
      "enum": [
        "freeze_ready",
        "blocked"
      ]
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "output_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_initialized_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
