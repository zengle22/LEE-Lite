{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ll-product-epic-to-feat output",
  "type": "object",
  "required": [
    "artifact_type",
    "status",
    "schema_version",
    "workflow_key",
    "workflow_run_id",
    "epic_freeze_ref",
    "src_root_id",
    "feat_refs",
    "downstream_workflows",
    "source_refs",
    "glossary",
    "prohibited_inference_rules",
    "integration_context"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "feat_freeze_package"
    },
    "status": {
      "type": "string",
      "enum": [
        "revised",
        "accepted",
        "frozen"
      ]
    },
    "schema_version": {
      "type": "string"
    },
    "workflow_key": {
      "type": "string",
      "const": "product.epic-to-feat"
    },
    "workflow_run_id": {
      "type": "string",
      "minLength": 1
    },
    "epic_freeze_ref": {
      "type": "string",
      "minLength": 1
    },
    "src_root_id": {
      "type": "string",
      "minLength": 1
    },
    "feat_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "downstream_workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "glossary": {
      "type": "array",
      "minItems": 1
    },
    "prohibited_inference_rules": {
      "type": "array",
      "minItems": 1
    },
    "integration_context": {
      "type": "object",
      "required": [
        "artifact_type",
        "schema_version",
        "context_ref",
        "workflow_inventory",
        "module_boundaries",
        "legacy_fields_states_interfaces",
        "canonical_ownership",
        "compatibility_constraints",
        "migration_modes",
        "legacy_invariants",
        "gate_audit_evidence",
        "source_refs"
      ],
      "properties": {
        "artifact_type": { "type": "string", "const": "integration_context" },
        "schema_version": { "type": "string" },
        "context_ref": { "type": "string" },
        "workflow_inventory": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "module_boundaries": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "legacy_fields_states_interfaces": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "canonical_ownership": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "compatibility_constraints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "migration_modes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "legacy_invariants": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "gate_audit_evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "feat_track_map": {
      "type": "array"
    },
    "epic_context": {
      "type": "object"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "feat_ref",
          "title",
          "goal",
          "business_value",
          "upstream_feat",
          "downstream_feat",
          "consumes",
          "produces",
          "authoritative_artifact",
          "gate_decision_dependency_feat_refs",
          "gate_decision_dependency",
          "admission_dependency_feat_refs",
          "admission_dependency",
          "dependency_kinds",
          "design_impact_required",
          "candidate_design_surfaces",
          "identity_and_scenario",
          "business_flow",
          "product_objects_and_deliverables",
          "collaboration_and_timeline",
          "acceptance_and_testability",
          "frozen_downstream_boundary"
        ],
        "properties": {
          "feat_ref": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "design_impact_required": { "type": "boolean" },
          "candidate_design_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "surface_map_required_reason": { "type": "string" },
          "ui_required": { "type": "boolean" }
        }
      }
    }
  },
  "additionalProperties": true
}
