{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Execution Evidence",
  "description": "Skill execution evidence for ll-qa-api-spec-to-tests",
  "type": "object",
  "required": ["input_spec", "output_files", "generated_at"],
  "properties": {
    "input_spec": {
      "type": "object",
      "required": ["path", "case_id", "coverage_id"],
      "properties": {
        "path": { "type": "string" },
        "case_id": { "type": "string" },
        "coverage_id": { "type": "string" },
        "validation_passed": { "type": "boolean" }
      }
    },
    "output_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "case_id", "compiles"],
        "properties": {
          "path": { "type": "string" },
          "case_id": { "type": "string" },
          "coverage_id": { "type": "string" },
          "compiles": { "type": "boolean" },
          "line_count": { "type": "integer" }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
